`timescale 1us / 1ns  // 时间单位 1us，精度 1ns

module tb_top2();

    // 1. 定义测试台内部的输入信号 (寄存器类型，用来模拟外部开关和按键)
    reg  CLK;
    reg  KIN;
    reg  SW1;  // 波形选择高位
    reg  SW0;  // 波形选择低位
    reg  SW3;  // 幅值选择高位
    reg  SW2;  // 幅值选择低位
    
    // 2. 定义测试台内部的输出信号 (线网类型，用来接收引脚输出)
    wire [6:0] AA;
    wire [6:0] BB;
    wire [6:0] CC;
    wire [7:0] out;    

    // 3. 实例化你的终极顶层大总装模块 (UUT)
    // 严丝合缝地对接你原理图里的引脚名字
    changable uut (
        .CLK (CLK),
        .KIN (KIN),
        .SW1 (SW1),
        .SW0 (SW0),
        .SW3 (SW3),
        .SW2 (SW2),
        .AA  (AA),
        .BB  (BB),
        .CC  (CC),
        .out (out)
    );

    // 4. 生成 1MHz 系统主时钟 (周期 1us)
    always #0.5 CLK = ~CLK;

    // 5. 编写自动化物理激励信号 (控制机器人的动作)
    initial begin
        // --- [系统上电初始化] ---
        CLK = 0;
        KIN = 1'b1;       // 按键默认未按下 (高电平)
        SW1 = 0; SW0 = 0; // 默认 00 档位：正弦波
        SW3 = 0; SW2 = 0; // 默认 00 档位：100% 满幅度
        
        // 观察初始状态 (跑 20ms，看几个完整的正弦波)
        #20000; 

        // ==========================================
        // 第一幕：多波形切换测试 (保持 100% 幅度)
        // ==========================================
        
        // 动作：切换到 01 档位 (三角波)
        SW1 = 0; SW0 = 1; 
        #20000; 
        
        // 动作：切换到 10 档位 (方波)
        SW1 = 1; SW0 = 0; 
        #20000; 
        
        // 动作：切换到 11 档位 (锯齿波/任意波)
        SW1 = 1; SW0 = 1; 
        #20000; 

        // ==========================================
        // 第二幕：幅值衰减测试 (切回正弦波以便观察高度变化)
        // ==========================================
        SW1 = 0; SW0 = 0; // 切回正弦波
        #10000;           // 稳定一下波形

        // 动作：切换到 01 档位 (50% 幅度，即 1/2)
        SW3 = 0; SW2 = 1; 
        #20000; 

        // 动作：切换到 10 档位 (25% 幅度，即 1/4)
        SW3 = 1; SW2 = 0; 
        #20000; 

        // 动作：切换到 11 档位 (12.5% 幅度，即 1/8)
        SW3 = 1; SW2 = 1; 
        #20000; 

        // ==========================================
        // 第三幕：按键变频测试 
        // ==========================================
        SW3 = 0; SW2 = 0; // 恢复 100% 满幅度，此时波形最好看
        
        // 动作：稳定按下按键 (维持 15ms，必须超过消抖模块需要的 10ms)
        KIN = 1'b0;
        #15000; 
        
        // 动作：松开按键
        KIN = 1'b1;
        
        // 留出 30ms 的空白时间，欣赏频率切换后“变密”的正弦波
        #30000; 

        // 剧终，停止仿真
        $stop;
    end

endmodule